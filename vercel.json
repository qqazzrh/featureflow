{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/dist/public/$1" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public"
}
